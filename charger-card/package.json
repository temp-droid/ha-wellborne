{
  "name": "wellborne-charger-card",
  "version": "1.0.0",
  "description": "Home Assistant Lovelace card for the Wellborne EV charger (monitoring, read-only).",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "esbuild src/wellborne-charger-card.ts --bundle --minify --format=esm --target=es2021 --outfile=dist/wellborne-charger-card.js",
    "dev": "esbuild src/wellborne-charger-card.ts --bundle --sourcemap --format=esm --target=es2021 --outfile=dist/wellborne-charger-card.js --watch",
    "preview": "npm run build && npx --yes serve .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["home-assistant", "lovelace", "ev-charger", "wellborne", "hacs"],
  "license": "MIT",
  "dependencies": {
    "lit": "^3.2.1"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.6.3"
  }
}
